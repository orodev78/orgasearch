APP_NAME=Orgasearch
APP_VERSION=0.2.0
OPENALEX_API_KEY=
WIKIDATA_USER_AGENT=Orgasearch/1.0 (contact@example.org)
CACHE_URL=
SEARCH_DEFAULT_LIMIT=30
SEARCH_PER_SOURCE_LIMIT=15
SEARCH_TIMEOUT_SECONDS=8
SEARCH_MAX_QUERY_LENGTH=500
SEARCH_MAX_LANGS=10
SEARCH_MAX_EXPANSIONS_DEFAULT=12
SEARCH_MIN_SCORE=0.45
RATE_LIMIT_GLOBAL=120/minute
RATE_LIMIT_SEARCH=30/minute
RATE_LIMIT_READ=60/minute
# Comma-separated browser origins (leave empty to disable CORS)
CORS_ORIGINS=
# Reverse proxy path prefix (empty at root; e.g. /orgasearch behind Traefik)
ROOT_PATH=
